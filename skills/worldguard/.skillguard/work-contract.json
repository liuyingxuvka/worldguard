      ],
      "required_checks": [
        "check_phase_order"
      ],
      "allowed_next": [
        "execution"
      ]
    },
    {
      "phase_id": "execution",
      "summary": "Perform the skill work inside the selected route without skipping declared gates.",
      "required_evidence": [
        "direct_evidence"
      ],
      "required_checks": [
        "check_evidence"
      ],
      "allowed_next": [
        "checks"
      ]
    },
    {
      "phase_id": "checks",
      "summary": "Run required checks, quality floors, freshness checks, and negative-case gates when applicable.",
      "required_evidence": [
        "check_output"
      ],
      "required_checks": [
        "check_quality_floor"
      ],
      "allowed_next": [
        "closure"
      ]
    },
    {
      "phase_id": "closure",
      "summary": "Close only inside the evidence-backed claim boundary.",
      "required_evidence": [
        "closure_report"
      ],
      "required_checks": [
        "check_closure"
      ],
      "allowed_next": []
